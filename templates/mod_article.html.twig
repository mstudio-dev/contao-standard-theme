{% set wrapperAttributes = attrs(cssID)
    .addClass([class, 'block'])
    .addStyle(style|default)
    .mergeWith(wrapperAttributes|default)
%}

{% if teaserOnly|default %}

    {% block alias %}
        <article{{ wrapperAttributes }}>
            <div class="ce_text block">
                <h2>{{ headline|insert_tag_raw }}</h2>
                <div class="teaser">
                    {{ teaser|default|sanitize_html('contao')|csp_inline_styles }}
                    <p class="more">
                        <a href="{{ href }}" title="{{ readMore }}">
                            {{ more }}
                            <span class="invisible">{{ headline }}</span>
                        </a>
                    </p>
                </div>
            </div>
        </article>
    {% endblock %}

{% elseif noMarkup|default %}

    {{ elements|join|raw }}

{% else %}

    <div{{ wrapperAttributes }}>
        {% if printable %}
            {% block syndication %}
                <!-- indexer::stop -->
                <nav class="syndication" aria-label="{{ 'Artikel teilen'|trans }}">
                    {% if printButton %}
                        <a href="{{ print }}" class="print" title="{{ printTitle }}"
                           onclick="window.print();return false"
                           data-skip-search-index>
                            <svg aria-hidden="true" focusable="false" width="16" height="16">
                                <use href="{{ asset('files/theme/img/sprite.svg') }}#icon-print"/>
                            </svg>
                            <span class="invisible">{{ printTitle }}</span>
                        </a>
                    {% endif %}
                    {% if facebookButton %}
                        <a href="{{ path('contao_frontend_share', {p: 'facebook', u: encUrl}) }}"
                           class="facebook" rel="nofollow" title="{{ facebookTitle }}"
                           onclick="var w=window.open(this.href,'','width=640,height=380,modal=yes,left=100,top=50,location=no,menubar=no,resizable=yes,scrollbars=yes,status=no,toolbar=no');w.opener=null;return false">
                            <span class="invisible">{{ facebookTitle }}</span>
                        </a>
                    {% endif %}
                    {% if twitterButton %}
                        <a href="{{ path('contao_frontend_share', {p: 'twitter', u: encUrl, t: encTitle}) }}"
                           class="twitter" rel="nofollow" title="{{ twitterTitle }}"
                           onclick="var w=window.open(this.href,'','width=640,height=380,modal=yes,left=100,top=50,location=no,menubar=no,resizable=yes,scrollbars=yes,status=no,toolbar=no');w.opener=null;return false">
                            <span class="invisible">{{ twitterTitle }}</span>
                        </a>
                    {% endif %}
                </nav>
                <!-- indexer::continue -->
            {% endblock %}
        {% endif %}

        <div class="inside">
            {% block content %}
                {{ elements|join|raw }}
            {% endblock %}
        </div>

        {% if backlink %}
            {% block backlink %}
                <!-- indexer::stop -->
                <p class="back">
                    <a href="{{ backlink }}" title="{{ back }}">
                        <svg aria-hidden="true" focusable="false" width="16" height="16">
                            <use href="{{ asset('files/theme/img/sprite.svg') }}#icon-arrow-left"/>
                        </svg>
                        {{ back }}
                    </a>
                </p>
                <!-- indexer::continue -->
            {% endblock %}
        {% endif %}

    </div>

{% endif %}
